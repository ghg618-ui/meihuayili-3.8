# 梅花义理代理服务器 — 密钥配置文件
# 复制此文件为 .env，填入真实密钥，.env 文件永远不会上传到 GitHub

# 硅基流动 API Key（主线，推荐填这个）
# 获取地址：https://cloud.siliconflow.cn/account/ak
SF_API_KEY=

# DeepSeek 官方 API Key（备线，可不填）
# 获取地址：https://platform.deepseek.com/api_keys
DS_API_KEY=

# 服务端口（默认 3210，可不改）
PORT=3210

# 允许访问的域名（逗号分隔，本地调试时已默认包含 localhost:5173）
ALLOWED_ORIGINS=https://meihuayili.com,http://localhost:5173
